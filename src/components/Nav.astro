---
const navLinks = [
  { href: "/notes", label: "notes" },
  { href: "/travel", label: "travel" },
];

const currentPath = new URL(Astro.request.url).pathname;
---

<header class="site-header">
  <nav class="nav container">
    <a href="/" class="nav__logo">maggie &amp; dustin</a>
    <ul class="nav__links">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={["nav__link", { "nav__link--active": currentPath.startsWith(href) }]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    background: var(--color-bg);
    z-index: 100;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 0.15s ease;
  }

  .nav__logo:hover {
    color: var(--color-accent);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    list-style: none;
  }

  @media (min-width: 400px) {
    .nav__links { gap: 2rem; }
  }

  .nav__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
    letter-spacing: 0.01em;
  }

  @media (min-width: 400px) {
    .nav__link { font-size: 0.9375rem; }
  }

  .nav__link:hover,
  .nav__link--active {
    color: var(--color-text);
  }
</style>
