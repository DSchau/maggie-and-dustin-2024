---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";

// Photos — add/remove images from src/assets/images/ and update this list.
import photoBossBaby        from "@/assets/images/boss-baby.jpeg";
import photoCroatia         from "@/assets/images/croatia-maggie-dustin.jpeg";
import photoEmilia          from "@/assets/images/emilia.jpeg";
import photoHalloween       from "@/assets/images/halloween.jpeg";
import photoMaggiePregnant  from "@/assets/images/maggie-pregnant.jpeg";
import photoNoahDada        from "@/assets/images/noah-dada-working.jpeg";
import photoNoah            from "@/assets/images/noah.jpeg";
import photoYosemite        from "@/assets/images/yosemite.jpeg";

const photos = [
  { src: photoCroatia,        alt: "Maggie and Dustin in Croatia" },
  { src: photoNoah,           alt: "Noah" },
  { src: photoYosemite,       alt: "Yosemite" },
  { src: photoEmilia,         alt: "Emilia" },
  { src: photoNoahDada,       alt: "Noah and dad working" },
  { src: photoBossBaby,       alt: "Boss baby" },
  { src: photoHalloween,      alt: "Halloween" },
  { src: photoMaggiePregnant, alt: "Maggie" },
];

// Calculate ages
function getAge(birthdate: Date): number {
  const today = new Date();
  let age = today.getFullYear() - birthdate.getFullYear();
  const monthDiff = today.getMonth() - birthdate.getMonth();
  if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthdate.getDate())) {
    age--;
  }
  return age;
}

const noahBirthdate = new Date("2023-02-10");
const emiliaBirthdate = new Date("2025-02-17");
const noahAge = getAge(noahBirthdate);
const emiliaAge = getAge(emiliaBirthdate);

// Get recent notes
const allPosts = await getCollection("posts");
const recentNotes = allPosts
  .filter((p) => p.data.category === "note")
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const recentTravel = allPosts
  .filter((p) => p.data.category === "travel")
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout title="" description="Maggie & Dustin — a family living and exploring from San Francisco, CA.">
  <!-- Hero -->
  <section class="hero">
    <div class="container--narrow">
      <h1 class="hero__headline">A family in San Francisco</h1>
      <p class="hero__sub">
        We're Maggie &amp; Dustin — writing about everyday life, our kids, and
        the places we go. This is our little corner of the internet.
      </p>
    </div>
  </section>

  <!-- Photo grid -->
  <section class="photos">
    <div class="photos__masonry">
      {photos.map((photo) => (
        <div class="photos__item">
          <Image src={photo.src} alt={photo.alt} widths={[400, 800]} sizes="(max-width: 640px) 50vw, 33vw" />
        </div>
      ))}
    </div>
  </section>

  <!-- Family bios -->
  <section class="family">
    <div class="container--narrow">
      <h2 class="section-title">the family</h2>
      <div class="family__grid">
        <div class="family__member">
          <div class="family__initial">D</div>
          <div class="family__info">
            <h3 class="family__name">Dustin</h3>
            <p class="family__bio">
              Product and engineering leader. Loves coffee, building things, and
              getting outdoors whenever San Francisco cooperates.
            </p>
          </div>
        </div>
        <div class="family__member">
          <div class="family__initial">M</div>
          <div class="family__info">
            <h3 class="family__name">Maggie</h3>
            <p class="family__bio">
              Creative, curious, and always finding the best restaurant in any
              city we visit. The planner behind our adventures.
            </p>
          </div>
        </div>
        <div class="family__member">
          <div class="family__initial">N</div>
          <div class="family__info">
            <h3 class="family__name">Noah &mdash; age {noahAge}</h3>
            <p class="family__bio">
              Born February 2023. Strong opinions about dinosaurs, trucks, and
              which parent is doing it wrong at any given moment.
            </p>
          </div>
        </div>
        <div class="family__member">
          <div class="family__initial">E</div>
          <div class="family__info">
            <h3 class="family__name">Emilia &mdash; age {emiliaAge}</h3>
            <p class="family__bio">
              Born February 2025. Watching the world with wide eyes and her
              brother's chaos with what appears to be great interest.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent Notes -->
  {recentNotes.length > 0 && (
    <section class="recent-section">
      <div class="container--narrow">
        <div class="section-header">
          <h2 class="section-title">recent notes</h2>
          <a href="/notes" class="section-link">all notes &rarr;</a>
        </div>
        {recentNotes.map((post) => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            excerpt={post.data.excerpt}
            tags={post.data.tags}
            slug={post.slug}
            category={post.data.category}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Recent Travel -->
  {recentTravel.length > 0 && (
    <section class="recent-section">
      <div class="container--narrow">
        <div class="section-header">
          <h2 class="section-title">recent travel</h2>
          <a href="/travel" class="section-link">all travel &rarr;</a>
        </div>
        {recentTravel.map((post) => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            excerpt={post.data.excerpt}
            tags={post.data.tags}
            slug={post.slug}
            category={post.data.category}
            location={post.data.location}
          />
        ))}
      </div>
    </section>
  )}
</Layout>

<style>
  /* Photo masonry grid — CSS columns for native masonry flow */
  .photos {
    padding: var(--space-8) 0 var(--space-10);
  }

  @media (min-width: 640px) {
    .photos { padding: var(--space-10) 0 var(--space-16); }
  }

  .photos__masonry {
    columns: 2;
    column-gap: 0.5rem;
    padding: 0 var(--space-5);
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .photos__masonry {
      columns: 3;
      column-gap: 0.75rem;
      padding: 0 var(--space-6);
    }
  }

  .photos__item {
    break-inside: avoid;
    margin-bottom: 0.5rem;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .photos__item { margin-bottom: 0.75rem; }
  }

  .photos__item img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.2s ease;
  }

  .photos__item:hover img {
    opacity: 0.92;
  }

  /* Hero */
  .hero {
    padding: var(--space-12) 0 var(--space-10);
  }

  @media (min-width: 640px) {
    .hero { padding: var(--space-20) 0 var(--space-16); }
  }

  .hero__headline {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 6vw, 3.75rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-5);
    color: var(--color-text);
  }

  .hero__sub {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 520px;
  }

  /* Family section */
  .family {
    padding: var(--space-10) 0;
    background: white;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .family { padding: var(--space-16) 0; }
  }

  .family__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-top: var(--space-8);
  }

  @media (min-width: 600px) {
    .family__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .family__member {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .family__initial {
    flex-shrink: 0;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: var(--color-accent-light);
    color: var(--color-accent);
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .family__name {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 600;
    margin-bottom: var(--space-2);
  }

  .family__bio {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* Section common */
  .recent-section {
    padding: var(--space-10) 0;
  }

  @media (min-width: 640px) {
    .recent-section { padding: var(--space-16) 0; }
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-8);
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .section-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
  }

  .section-link:hover {
    color: var(--color-text);
  }
</style>
