---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import Globe from "@/components/Globe";

const travelPosts = await getCollection("posts", ({ data }) => data.category === "travel");
travelPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Build globe locations from posts that have coordinates
const globeLocations = travelPosts
  .filter((p) => p.data.coordinates)
  .map((p) => ({
    lat: p.data.coordinates![0],
    lng: p.data.coordinates![1],
    label: p.data.location ?? p.data.title,
  }));
---

<Layout
  title="Travel"
  description="Places we've explored as a family, from Kauai to our home in San Francisco."
>
  <div class="page">
    <div class="container--narrow">
      <header class="page-header">
        <h1 class="page-title">Travel</h1>
        <p class="page-description">
          Adventures near and far. We try to see as much as we can — with or
          without the kids cooperating.
        </p>
      </header>
    </div>

    <!-- Globe -->
    {globeLocations.length > 0 && (
      <div class="globe-wrapper">
        <Globe locations={globeLocations} client:visible />
      </div>
    )}

    <!-- Post listing -->
    <div class="container--narrow posts-section">
      {travelPosts.map((post) => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          excerpt={post.data.excerpt}
          tags={post.data.tags}
          slug={post.slug}
          category={post.data.category}
          location={post.data.location}
        />
      ))}
      {travelPosts.length === 0 && (
        <p class="empty">No travel posts yet — adventure is coming.</p>
      )}
    </div>
  </div>
</Layout>

<style>
  .page {
    padding: var(--space-10) 0;
  }

  @media (min-width: 640px) {
    .page { padding: var(--space-16) 0; }
  }

  .page-header {
    margin-bottom: var(--space-8);
  }

  @media (min-width: 640px) {
    .page-header { margin-bottom: var(--space-12); }
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .page-description {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    max-width: 480px;
  }

  .globe-wrapper {
    width: 100%;
    max-width: 340px;
    margin: 0 auto var(--space-10);
    padding: 0 var(--space-5);
  }

  @media (min-width: 480px) {
    .globe-wrapper {
      max-width: 520px;
      margin-bottom: var(--space-16);
      padding: 0 var(--space-6);
    }
  }

  .posts-section {
    margin-top: var(--space-8);
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
