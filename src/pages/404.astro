---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Page Not Found">
  <div class="not-found">
    <div class="container--narrow">
      <h1 class="not-found__heading">404</h1>
      <p class="not-found__message">
        We couldn't find that page. Maybe try the{" "}
        <a href="/">home page</a> or browse our{" "}
        <a href="/notes">notes</a> and{" "}
        <a href="/travel">travel posts</a>.
      </p>
    </div>
  </div>
</Layout>

<style>
  .not-found {
    padding: var(--space-24) 0;
    text-align: center;
  }

  .not-found__heading {
    font-family: var(--font-serif);
    font-size: 6rem;
    font-weight: 600;
    color: var(--color-border);
    line-height: 1;
    margin-bottom: var(--space-6);
  }

  .not-found__message {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }
</style>
